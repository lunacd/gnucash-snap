   endif()
 
+  if (UNIX)
+    set_target_properties(sw_core_utils PROPERTIES INSTALL_RPATH
+      "$ORIGIN/..;$ORIGIN"
+    )
+  endif()
+
   install(TARGETS sw_core_utils
     LIBRARY DESTINATION ${PYTHON_SYSCONFIG_OUTPUT}/gnucash
     ARCHIVE DESTINATION ${PYTHON_SYSCONFIG_OUTPUT}/gnucash
@@ -177,6 +189,12 @@ if(WITH_PYTHON)
     set_target_properties (sw_app_utils PROPERTIES INSTALL_NAME_DIR "${CMAKE_INSTALL_FULL_LIBDIR}")
   endif()
 
+  if (UNIX)
+    set_target_properties(sw_app_utils PROPERTIES INSTALL_RPATH
+      "$ORIGIN/..;$ORIGIN"
+    )
+  endif()
+
   install(TARGETS sw_app_utils
           LIBRARY DESTINATION ${PYTHON_SYSCONFIG_OUTPUT}/gnucash
           ARCHIVE DESTINATION ${PYTHON_SYSCONFIG_OUTPUT}/gnucash
diff --git a/gnucash/CMakeLists.txt b/gnucash/CMakeLists.txt
index 731ad4adf0..7a1b39bd95 100644
--- a/gnucash/CMakeLists.txt
+++ b/gnucash/CMakeLists.txt
@@ -165,6 +165,12 @@ if (COVERAGE AND LCOV_VERSION VERSION_GREATER_EQUAL "2.0")
   add_coverage_target(gnucash-cli)
 endif()
 
+if (UNIX)
+  set_target_properties(gnucash gnucash-cli PROPERTIES INSTALL_RPATH
+    "$ORIGIN/../lib/${CMAKE_LIBRARY_ARCHITECTURE};$ORIGIN/../lib/${CMAKE_LIBRARY_ARCHITECTURE}/gnucash"
+  )
+endif()
+
 install(TARGETS gnucash gnucash-cli DESTINATION ${CMAKE_INSTALL_BINDIR})
