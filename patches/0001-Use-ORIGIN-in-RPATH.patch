diff --git a/CMakeLists.txt b/CMakeLists.txt
index 06d29db494..635e0deeb8 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -695,10 +695,6 @@ if (APPLE AND WITH_GNUCASH)
   set(CMAKE_INSTALL_NAME_DIR "${CMAKE_INSTALL_FULL_LIBDIR}")
 endif()
 
-if (UNIX)
-  set(CMAKE_INSTALL_RPATH "${CMAKE_INSTALL_FULL_LIBDIR}:${CMAKE_INSTALL_FULL_LIBDIR}/gnucash")
-endif()
-
 set(BUILD_SHARED_LIBS ON)
 
 # Most libraries are installed to lib/gnucash, so set that as the default.
diff --git a/bindings/guile/CMakeLists.txt b/bindings/guile/CMakeLists.txt
index fc14fcd12c..b0cfb40a67 100644
--- a/bindings/guile/CMakeLists.txt
+++ b/bindings/guile/CMakeLists.txt
@@ -82,6 +82,12 @@ target_link_libraries(gnucash-guile
         gnc-app-utils
         PkgConfig::GLIB2)
 
+if (UNIX)
+  set_target_properties(gnucash-guile PROPERTIES INSTALL_RPATH
+    "$ORIGIN;$ORIGIN/gnucash"
+  )
+endif()
+
 install(TARGETS gnucash-guile
     LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
     ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR}
@@ -103,6 +109,12 @@ target_link_libraries(gnc-expressions-guile
         ${GUILE_LDFLAGS}
         PkgConfig::GLIB2)
 
+if (UNIX)
+  set_target_properties(gnc-expressions-guile PROPERTIES INSTALL_RPATH
+    "$ORIGIN;$ORIGIN/gnucash"
+  )
+endif()
+
 install(TARGETS gnc-expressions-guile
         LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
         ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR}
diff --git a/bindings/python/CMakeLists.txt b/bindings/python/CMakeLists.txt
index d37d047fd0..e76358f08a 100644
--- a/bindings/python/CMakeLists.txt
+++ b/bindings/python/CMakeLists.txt
@@ -98,6 +98,12 @@ if(WITH_PYTHON)
